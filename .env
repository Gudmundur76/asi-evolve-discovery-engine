# ASI-Evolve Discovery Engine — HIV Protease Configuration
# Overrides config.py defaults via MDE_ prefix (pydantic-settings)

MDE_PROJECT_NAME=HIV Protease Discovery Engine
MDE_TARGET_CHEMBL_ID=CHEMBL2094253
MDE_TARGET_NAME=HIV-1 Protease
MDE_ACTIVITY_TYPE=IC50
MDE_ACTIVITY_LIMIT=5000

MDE_FINGERPRINT_RADIUS=2
MDE_FINGERPRINT_NBITS=2048

MDE_N_ESTIMATORS=200
MDE_MAX_DEPTH=20
MDE_TEST_SIZE=0.2
MDE_RANDOM_STATE=42

MDE_DATA_DIR=data
MDE_MODEL_PATH=data/model.pkl
MDE_MODEL_METADATA_PATH=data/model_metadata.json

# Citation verification
MDE_CITATION_IS_URL=https://citation.manus.space
MDE_CITATION_IS_VERTICAL=hiv_protease
MDE_CITATION_CONFIDENCE_THRESHOLD=0.85

# Convergence detection
MDE_CONVERGENCE_TANIMOTO_THRESHOLD=0.70
MDE_CONVERGENCE_MIN_TRACKS=2

# Persistent logging
MDE_PERSISTENT_DRIVE_REPO=Gudmundur76/manus-persistent-drive
